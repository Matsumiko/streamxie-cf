  "description": "streamXie streaming catalog and watch experience backed by selected provider APIs.",
  "license": "MIT",
  "source": "./index.html",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Matsumiko/streamXie.git"
